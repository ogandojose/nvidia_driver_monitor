{
  "server": {
    "port": 8080,
    "https_port": 8443,
    "enable_https": false
  },
  "cache": {
    "refresh_interval": "15m",
    "enabled": true
  },
  "rate_limit": {
    "requests_per_minute": 60,
    "enabled": true
  },
  "http": {
    "timeout": "30s",
    "retries": 5,
    "user_agent": "nvidia-driver-monitor/1.0",
    "forgejo_token": ""
  },
  "processing": {
    "max_concurrency": 10
  }
}
